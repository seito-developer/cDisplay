{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Skill(update-config)",
      "Bash(swiftlint version:*)",
      "Bash(swift-format --version)",
      "Bash(xcodebuild -version)",
      "Bash(brew install:*)",
      "Bash(swiftlint lint:*)",
      "Bash(jq:*)",
      "Bash(xcodebuild -scheme cDisplay -configuration Debug build)",
      "Bash(xcodebuild -scheme cDisplay -configuration Debug -destination 'platform=macOS' build)",
      "Bash(xcodebuild test:*)",
      "Bash(xcodebuild -scheme cDisplay -configuration Debug -destination 'platform=macOS' build CONFIGURATION_BUILD_DIR=/tmp/cDisplay-build)",
      "Bash(open /tmp/cDisplay-build/cDisplay.app)",
      "Bash(osascript -e 'tell application \"\"System Events\"\" to \\(name of every window of process \"\"cDisplay\"\"\\)')",
      "Bash(kill 6984)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; echo \"$f\" | grep -q '\\.swift$' && /opt/homebrew/bin/swiftlint lint \"$f\" 2>&1 || true; }",
            "statusMessage": "SwiftLint..."
          }
        ]
      }
    ]
  }
}
